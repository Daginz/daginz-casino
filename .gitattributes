# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto eol=lf

# Keep these as LF always (shell/go/yaml are LF-sensitive)
*.sh   text eol=lf
*.go   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary-ish: never touch
*.png binary
*.jpg binary
*.drawio text eol=lf
