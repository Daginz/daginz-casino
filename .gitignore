# Claude Code / AI assistant artifacts (never commit)
# NOTE: do NOT add a bare `memory/` — it false-matches src dirs like
# apps/wallet/internal/ledger/adapters/memory/. Claude's memory lives outside
# the repo (~/.claude/...), and .claude/ already covers any in-repo case.
.claude/
CLAUDE.md
**/CLAUDE.local.md
.aider*
.cursor/

# dependencies
node_modules/
.pnpm-store/

# builds
dist/
build/
.next/
out/
*.tsbuildinfo

# go
apps/wallet/bin/
apps/wallet/tmp/
apps/wallet/.gotmp/
apps/wallet/*.out.log
apps/wallet/*.err.log

# env
.env
.env.local
.env.*.local
!.env.example

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# editor / os
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
Thumbs.db

# docker volumes (if mapped locally)
infra/.data/

# evm
apps/contracts-evm/cache/
apps/contracts-evm/artifacts/
apps/contracts-evm/typechain-types/

# local onchain env (contains testnet owner key)
apps/backend/.env*
!apps/backend/.env.example

# test artifacts
apps/backend/jest-out.txt
apps/backend/coverage/
