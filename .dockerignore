# Never copy host dependencies/build output into images — they break pnpm's
# installed symlinks and bloat the build context.
**/node_modules
**/.next
**/dist
**/build
**/out
**/*.tsbuildinfo

# Go build output
apps/wallet/bin
apps/wallet/tmp

# EVM build artifacts (recompiled in-image)
apps/contracts-evm/cache
apps/contracts-evm/artifacts
apps/contracts-evm/typechain-types

# VCS / tooling / secrets
.git
.gitignore
.claude
CLAUDE.md
memory
**/.env
**/.env.local
**/.env.*.local

# docs/research not needed in images
docs
infra/.data

# logs
**/*.log
