# Frontend runtime config (copy to .env.local). All public — no secrets here.

# Casino backend (NestJS) base URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Chain the backend listener watches. Dev = Hardhat (31337); Sepolia = 11155111.
NEXT_PUBLIC_CHAIN_ID=31337

# RPC the wallet/reads use for the active chain.
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<key>

# Deployed contract addresses (from contracts-evm deploy output).
NEXT_PUBLIC_CHIP_TOKEN_ADDRESS=
NEXT_PUBLIC_VAULT_ADDRESS=
